            "keyColor": "35",  // = color3
        },
        {
            "type": "os",
            "key": " ",
            "keyColor": "35",  // = color3
        },
        {
            "type": "kernel",
            "key": " ",
            "keyColor": "35",
        },
        {
            "type": "packages",
            "key": " ",
            "keyColor": "35",  
        },
        {
