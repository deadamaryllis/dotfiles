{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "auto",
        "source": "~/Documents/ascii/plan9.txt",
        /* "height": 22,
        "padding": {
            "top": 0,
            "right": 0,
            "bottom": 0
        },*/
        "color": { "1": "white" }
    },
    "display": {
        "separator": " "
    },
    "modules": [
      /*
	"break",
	"break",
  "break",
  "break",
  "break",
  "break",
  "break",
  "break",
  "break",
  "break",
  */
          {
            "type": "host",
